# =============================================================================
# Cascade — environment variables
# Copy this file to `.env` and fill in real values. `.env` is gitignored.
# In production, all of these live as Vercel Environment Variables (Settings →
# Environment Variables in the cascade Vercel project dashboard). Local-only
# work uses `.env` loaded by python-dotenv at process boot.
# =============================================================================

# ---- AWS Aurora PostgreSQL Serverless v2 -----------------------------------
# Connection string from Vercel Storage tab → ripple-aurora-pg → Show secrets.
# When provisioned via the Vercel Marketplace AWS Databases integration, this
# auto-populates as DATABASE_URL or POSTGRES_URL in the linked Vercel project.
DATABASE_URL=postgres://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require
# Aliases — Vercel/AWS sometimes set one or the other:
POSTGRES_URL=
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=
POSTGRES_PASSWORD=
POSTGRES_DATABASE=

# ---- AWS DynamoDB -----------------------------------------------------------
# Single-table design — one table holds events_stream, user_memory, watchlists
# distinguished by PK prefix (EVENT#..., USER#..., WATCHLIST#...).
DYNAMODB_TABLE=ripple-dynamodb
AWS_REGION=ap-south-1
# Credentials. Vercel Marketplace integration injects these automatically.
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Optional — only set when using DynamoDB Local for offline dev.
DYNAMODB_ENDPOINT_URL=

# ---- DynamoDB Streams → EventBridge Pipe → Vercel webhook ------------------
# Shared secret on the api/internal/dynamo-event Vercel Function endpoint.
# EventBridge Pipe sends this in an HMAC-signed header so the function can
# verify the source.
DYNAMO_WEBHOOK_SECRET=change-me

# ---- Voyage AI -------------------------------------------------------------
# 200M tokens free for new accounts. 3 RPM cap until a payment method is added
# at dashboard.voyageai.com/billing (no charge — just lifts the rate limit).
VOYAGE_API_KEY=pa-...
VOYAGE_TEXT_MODEL=voyage-4
VOYAGE_MULTIMODAL_MODEL=voyage-multimodal-3
VOYAGE_RERANK_MODEL=rerank-2.5

# ---- Google Gemini (external API call — no GCP infrastructure) -------------
# AI Studio API key. Get one at https://aistudio.google.com/apikey.
# No GCP project, no service account, no ADC required — just the key.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_GEO_MODEL=gemini-3-flash-preview

# ---- Data sources ----------------------------------------------------------
# SEC EDGAR REQUIRES a User-Agent header — requests without it are blocked.
SEC_USER_AGENT=Cascade research/your-email@example.com

FINNHUB_API_KEY=
MARKETAUX_API_KEY=
ALPHA_VANTAGE_API_KEY=

REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=cascade-research/0.1 by your-reddit-username

# ---- App config ------------------------------------------------------------
LOG_LEVEL=INFO

# ---- Frontend (web/) -------------------------------------------------------
# Public — exposed to the browser. In production these point at the Vercel
# project's own deployment URL (e.g. https://cascade-terminal.vercel.app/api/...).
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_SSE_URL=http://localhost:3000/api/stream
