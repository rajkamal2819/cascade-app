# =============================================================================
# Cascade — environment variables
# Copy to `.env` for local dev. In production, all of these live as Vercel
# Environment Variables on the cascade-app project.
# =============================================================================

# ---- AWS Aurora PostgreSQL Serverless v2 -----------------------------------
# Auto-injected by the Vercel Marketplace AWS Databases integration when
# `ripple-aurora-pg` is connected to the project (prefix: POSTGRES).
# Authentication is RDS IAM via Vercel OIDC — no static password.
POSTGRES_PGHOST=ripple-aurora-pg.cluster-xxx.ap-south-1.rds.amazonaws.com
POSTGRES_PGPORT=5432
POSTGRES_PGUSER=postgres
POSTGRES_PGDATABASE=postgres
POSTGRES_PGSSLMODE=require
POSTGRES_AWS_REGION=ap-south-1
POSTGRES_AWS_ACCOUNT_ID=
POSTGRES_AWS_RESOURCE_ARN=arn:aws:rds:ap-south-1:ACCOUNT:cluster:ripple-aurora-pg
POSTGRES_AWS_ROLE_ARN=arn:aws:iam::ACCOUNT:role/Vercel/access-ripple-aurora-pg

# ---- AWS DynamoDB -----------------------------------------------------------
# Auto-injected by the Marketplace integration (prefix: DYNAMODB).
# Single-table design — one table holds events_stream, user_memory, watchlists
# distinguished by PK prefix (EVENT#..., USER#..., WATCHLIST#...).
DYNAMODB_TABLE_NAME=ripple-dynamodb
DYNAMODB_TABLE_PARTITION_KEY=PK
DYNAMODB_TABLE_SORT_KEY=SK
DYNAMODB_AWS_REGION=ap-south-1
DYNAMODB_AWS_ACCOUNT_ID=
DYNAMODB_AWS_RESOURCE_ARN=arn:aws:dynamodb:ap-south-1:ACCOUNT:table/ripple-dynamodb
DYNAMODB_AWS_ROLE_ARN=arn:aws:iam::ACCOUNT:role/Vercel/access-ripple-dynamodb

# ---- DynamoDB Streams → EventBridge Pipe → Vercel webhook ------------------
DYNAMO_WEBHOOK_SECRET=change-me

# ---- Cron dispatch shared secret -------------------------------------------
# Sent by AWS EventBridge Scheduler (or any external invoker) to authenticate
# requests to /api/cron/dispatch_workers.
CRON_SECRET=change-me

# ---- Voyage AI -------------------------------------------------------------
VOYAGE_API_KEY=pa-...
VOYAGE_TEXT_MODEL=voyage-4
VOYAGE_MULTIMODAL_MODEL=voyage-multimodal-3
VOYAGE_RERANK_MODEL=rerank-2.5

# ---- Google Gemini (external API call — no GCP infrastructure) -------------
GEMINI_API_KEY=
GEMINI_MODEL=gemini-3-flash-preview
GEMINI_GEO_MODEL=gemini-3-flash-preview

# ---- Data sources ----------------------------------------------------------
SEC_USER_AGENT=Cascade research/your-email@example.com
FINNHUB_API_KEY=
MARKETAUX_API_KEY=
ALPHA_VANTAGE_API_KEY=
REDDIT_CLIENT_ID=
REDDIT_CLIENT_SECRET=
REDDIT_USER_AGENT=cascade-research/0.1 by your-reddit-username

# ---- App config ------------------------------------------------------------
LOG_LEVEL=INFO

# ---- Frontend (web/) -------------------------------------------------------
NEXT_PUBLIC_API_URL=http://localhost:3000/api
NEXT_PUBLIC_SSE_URL=http://localhost:3000/api/stream
